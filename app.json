{
  "expo": {
    "name": "CurriculoUpdated",
    "slug": "curriculo-portifolio",
    "owner": "c3webmobile2026.1",
    "version": "1.0.0",
    "scheme": "curriculo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101124"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pedrodutra.curriculowebmobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101124"
      },
      "package": "com.pedrodutra.curriculowebmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "src/app"
      },
      "eas": {
        "projectId": "442ad851-bcd8-41cd-a820-fde4f1197273"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/442ad851-bcd8-41cd-a820-fde4f1197273"
    }
  }
}
